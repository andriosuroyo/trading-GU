# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Agent-specific files (local only)
.agents/

# Archives (keep structure, ignore large files)
archive/*.zip
archive/*.tar
archive/*.rar

# Large data files - excluded from git
*.parquet
data/*.csv
data/*.json

# Keep folder structures
!**/.gitkeep
