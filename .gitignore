# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Agent-specific files (local only) - MOVED to track .agents/
# .agents/ is now tracked for staff coordination

# Compiled MQL5 files (generated from source)
*.ex5

# Excel lock files
~$*.xlsx
*.xlk

# Recovery CSV files (runtime generated)
recovery_*.csv

# Temporary analysis outputs
*.tmp
*.temp

# Archives (keep structure, ignore large files)
archive/*.zip
archive/*.tar
archive/*.rar

# Large data files - excluded from git
*.parquet
data/*.csv
data/*.json

# Keep folder structures
!**/.gitkeep
